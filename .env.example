# Copy this file to .env on the server and fill real values there.
# Never commit .env with real secrets.

BOT_TOKEN=replace_with_telegram_bot_token
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_strong_admin_password
SUPER_ADMIN_TELEGRAM_ID=123456789

# Use PostgreSQL in production/staging. Fill the full URL in your private .env file.
DATABASE_URL=postgresql://REPLACE_WITH_PRIVATE_DATABASE_URL

# Optional comma-separated Telegram seller IDs.
SELLER_CHAT_IDS=

# Optional Flask session secret. Strongly recommended in production.
FLASK_SECRET=replace_with_random_secret

# Optional public payment/contact text shown on recharge page.
ALIPAY_PAYMENT_TEXT=请联系站主获取支付宝收款信息
WECHAT_PAYMENT_TEXT=请联系站主获取微信收款信息
